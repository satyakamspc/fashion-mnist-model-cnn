   "source": [
    "#Creating a model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-20T17:24:35.115179Z",
     "iopub.status.busy": "2026-03-20T17:24:35.114823Z",
     "iopub.status.idle": "2026-03-20T17:24:35.123032Z",
     "shell.execute_reply": "2026-03-20T17:24:35.122086Z",
     "shell.execute_reply.started": "2026-03-20T17:24:35.115148Z"
    },
    "id": "9JqhVygc3pc-",
    "trusted": true
   },
   "outputs": [],
   "source": [
    "\n",
    "class CustomModel(nn.Module):\n",
    "    def __init__(self, inpt, hidden, output):\n",
    "        super().__init__()\n",
    "\n",
    "        self.layer1 = nn.Sequential(\n",
    "            nn.Conv2d(inpt, hidden, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(hidden, hidden, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2)   # 32 → 16\n",
    "        )\n",
    "\n",
    "        self.layer2 = nn.Sequential(\n",
    "            nn.Conv2d(hidden, hidden, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(hidden, hidden, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2)   # 16 → 8\n",
    "        )\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(hidden*8*8, hidden),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(hidden, output)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.layer1(x)\n",
    "        x = self.layer2(x)\n",
    "        x = self.classifier(x)\n",
    "        return x"
   ]
  },
